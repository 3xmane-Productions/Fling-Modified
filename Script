-- Update status display
local function CountSelectedTargets()
    local count = 0
    for _ in pairs(SelectedTargets) do
        count = count + 1
    end
    return count
end

local function UpdateStatus()
    local count = CountSelectedTargets()
    if FlingActive then
        StatusLabel.Text = "Flinging target..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        StatusLabel.Text = count .. " target(s) selected" 
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

-- Assign and display the selected player safely
local function SetSelectedPlayer(targetPlayer)
    SelectedTargets = {} -- Resetea la lista previa para un solo objetivo
    if targetPlayer and targetPlayer ~= Player then
        currentTarget = targetPlayer
        SelectedTargets[targetPlayer.Name] = targetPlayer
        SelectedLabel.Text = "Selected: " .. targetPlayer.DisplayName .. " (@" .. targetPlayer.Name .. ")"
    else
        currentTarget = nil
        SelectedLabel.Text = "Selected: None"
    end
    UpdateStatus()
end

-- Auto-complete logic based on first letters typed
SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local text = SearchBox.Text
    if text == "" then
        SetSelectedPlayer(nil)
        return
    end
    
    local found = false
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            -- Evalúa si coincide el inicio del Username o DisplayName
            if string.sub(p.Name:lower(), 1, #text) == text:lower() or string.sub(p.DisplayName:lower(), 1, #text) == text:lower() then
                SetSelectedPlayer(p)
                found = true
                break
            end
        end
    end
    if not found then
        SetSelectedPlayer(nil)
    end
end)

-- Click To Select World-Interaction Logic
local clickConnection
ClickSelectButton.MouseButton1Click:Connect(function()
    if isSelectingMode then return end
    isSelectingMode = true
    ClickSelectButton.Text = "SELECTING..."
    ClickSelectButton.BackgroundColor3 = Color3.fromRGB(200, 140, 0)
    
    clickConnection = Mouse.Button1Down:Connect(function()
        local target3D = Mouse.Target
        if target3D then
            local charModel = target3D:FindFirstAncestorOfClass("Model")
            if charModel then
                local clickedPlayer = Players:GetPlayerFromCharacter(charModel)
                if clickedPlayer and clickedPlayer ~= Player then
                    SetSelectedPlayer(clickedPlayer)
                    SearchBox.Text = clickedPlayer.Name
                end
            end
        end
        -- Termina el modo selección tras un click
        isSelectingMode = false
        ClickSelectButton.Text = "CLICK TO SELECT"
        ClickSelectButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        if clickConnection then
            clickConnection:Disconnect()
        end
    end)
end)

