game:GetService("Workspace").FallenPartsDestroyHeight = 0/0

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ZERO_VECTOR = Vector3.zero

-- Usamos un booleano, es mucho más rápido y ligero de procesar que comparar IDs en cada frame
local isSpoofingActive = false 

local function iniciarScript(character)
    -- 1. Apagamos cualquier proceso anterior por seguridad antes de iniciar uno nuevo
    isSpoofingActive = false 
    
    if not character then return end

    local humanoid = character:WaitForChild("Humanoid", 5)
    local hrp = character:WaitForChild("HumanoidRootPart", 5)

    -- Si algo falló en la carga del juego, cancelamos para evitar errores rojos
    if not humanoid or not hrp then return end

    -- 2. Encendemos el interruptor para el nuevo personaje
    isSpoofingActive = true

    -- 3. EVENTO DE MUERTE: Esta es la clave. Apaga el script instantáneamente en el frame que mueres.
    local connectionMuerte
    connectionMuerte = humanoid.Died:Connect(function()
        isSpoofingActive = false -- Esto rompe el ciclo 'while' de abajo al instante
        if connectionMuerte then
            connectionMuerte:Disconnect()
            connectionMuerte = nil
        end
    end)

    -- 4. El ciclo de spoofing (ahora mucho más limpio)
    task.spawn(function()
        -- El ciclo solo vive mientras isSpoofingActive sea true y las partes existan
        while isSpoofingActive and character.Parent and hrp.Parent do
            local currentVelocity = hrp.AssemblyLinearVelocity
            hrp.AssemblyLinearVelocity = ZERO_VECTOR
            
            -- Esperamos al renderizado
            RunService.RenderStepped:Wait()
            
            -- Verificación ultra rápida antes de regresar la velocidad
            if isSpoofingActive and hrp.Parent then
                hrp.AssemblyLinearVelocity = currentVelocity
            end
            
            -- Sincronizamos con las físicas del servidor
            RunService.Heartbeat:Wait()
        end
    end)
end

-- Se ejecuta cada vez que el juego te da un nuevo personaje (reaparición)
LocalPlayer.CharacterAdded:Connect(function(nuevoPersonaje)
    iniciarScript(nuevoPersonaje)
end)

-- Arranque inicial por si ya estabas vivo al inyectar el script
if LocalPlayer.Character then
    local currentHumanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    -- Solo arrancamos si estás vivo al momento de inyectar
    if currentHumanoid and currentHumanoid.Health > 0 then
        iniciarScript(LocalPlayer.Character)
    end
end
